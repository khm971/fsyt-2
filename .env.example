# Database (default: existing PostgreSQL at 10.50.1.250)
# From Windows Docker Desktop, 10.50.1.250 may be reachable; otherwise use host.docker.internal and ensure DB is bound to accept connections.
DATABASE_URL=postgresql://postgres:farstar@10.50.1.250/fsyt2

# Media storage: SMB credentials for \\10.50.1.250\Media\FSyt2 (used by CIFS volume in docker-compose)
# Create .env from this file and set your Windows/SMB username and password.
SMB_USER=your_username
SMB_PASS=your_password

# Frontend (when running frontend outside Docker)
# VITE_API_URL=http://localhost:8000/api
# VITE_WS_URL=ws://localhost:8000

# Jellyfin integration (Admin > Jellyfin). Optional; defaults work for initial setup.
# JELLYFIN_URL=https://jellyfin.snake-lime.ts.net
# JELLYFIN_API_KEY=your_api_key
# JELLYFIN_PATH_PREFIX=/data/fsyt2
